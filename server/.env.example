# Required: key used to encrypt stored Hetzner API tokens at rest.
# Generate one: openssl rand -hex 32
APP_SECRET=

# Optional (defaults shown)
APP_NAME=hetzner-cost-monitor
DB_PATH=./hacm.db
PORT=3000
# Client origin allowed for cookie auth. Leave unset to reflect any origin (self-host).
FRONTEND_URL=http://localhost:3001
AUTH_COOKIE_KEY=hacm_session
COOKIE_SECURE=false
POLL_INTERVAL_MS=10000
PRICING_TTL_MS=3600000
